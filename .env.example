# AI assistant providers — set at least one to enable the "AI Assist" tab.
# The model selector only offers providers whose key is present here.
# Copy this file to .env.local and fill in the keys you have.

# Anthropic (Claude): https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter (many models behind one key): https://openrouter.ai/keys
OPENROUTER_API_KEY=
